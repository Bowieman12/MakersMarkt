<Page
    x:Class="MakersMarkt.Pages.Login.RegisterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F4EBD0">

    <Grid>
        <ScrollViewer HorizontalScrollMode="Disabled" VerticalScrollMode="Auto">
            <Border
                Background="White"
                CornerRadius="10"
                Padding="32"
                MinWidth="800"
                MaxWidth="1100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="24">
                <StackPanel HorizontalAlignment="Stretch">

                    <TextBlock Text="Registreren"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Margin="0,0,0,18" />

                    <TextBlock Text="Naam:" FontSize="16" Margin="0,4,0,6"/>
                    <TextBox x:Name="NameTextBlock" Height="48" FontSize="16" PlaceholderText="Naam..."/>

                    <TextBlock Text="Email:" FontSize="16" Margin="0,12,0,6"/>
                    <TextBox x:Name="EmailTextBlock" Height="48" FontSize="16"/>

                    <TextBlock Text="Wachtwoord:" FontSize="16" Margin="0,12,0,6"/>
                    <PasswordBox x:Name="PasswordPasswordBox" Height="48" FontSize="16"/>

                    <TextBlock Text="Bevestig Wachtwoord:" FontSize="16" Margin="0,12,0,6"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Height="48" FontSize="16"/>

                    <TextBlock Text="Rol:" FontSize="16" Margin="0,12,0,6"/>
                    <ComboBox x:Name="RoleComboBox"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Height="44"
                              FontSize="16"
                              Margin="0,0,0,6"/>

                    <Button x:Name="SaveButton"
                            Click="SaveButton_Click"
                            Content="Registreer"
                            Height="54"
                            FontSize="18"
                            Margin="0,14,0,0"/>

                    <TextBlock x:Name="ErrorTextBlock" Foreground="Red" FontSize="14" Margin="0,10,0,0"/>
                    <HyperlinkButton Content="Heb je al een account? Log in!"
                                     HorizontalAlignment="Center"
                                     FontSize="14"
                                     Foreground="#B2AC88"
                                     Click="HyperlinkButton_Click"
                                     Margin="0,14,0,0"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>