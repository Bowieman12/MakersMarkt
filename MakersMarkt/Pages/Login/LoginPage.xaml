<Page
    x:Class="MakersMarkt.Pages.Login.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F4EBD0">

    <Grid>
        <ScrollViewer HorizontalScrollMode="Disabled" VerticalScrollMode="Auto">
            <Border
                Background="White"
                CornerRadius="10"
                Padding="32"
                MinWidth="700"
                MaxWidth="1000"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="24">
                <StackPanel HorizontalAlignment="Stretch">
                    <TextBlock Text="Login"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Margin="0,0,0,18" />

                    <TextBlock Text="Gebruikers Naam:"
                               FontSize="16"
                               Margin="0,4,0,6" />
                    <TextBox x:Name="UsernameTextBox"
                             Height="48"
                             FontSize="16" />

                    <TextBlock Text="Wachtwoord:"
                               FontSize="16"
                               Margin="0,12,0,6" />
                    <PasswordBox x:Name="PasswordPasswordBox"
                                 Height="48"
                                 FontSize="16" />

                    <TextBlock x:Name="ErrorTextBlock"
                               Foreground="Red"
                               FontSize="14"
                               Margin="0,10,0,0" />

                    <Button x:Name="LoginButton"
                            Click="LoginButton_Click"
                            Content="Login"
                            Height="54"
                            FontSize="18"
                            Margin="0,16,0,0" />

                    <HyperlinkButton Content="Heb je nog geen account? Registreer!"
                                     HorizontalAlignment="Center"
                                     FontSize="14"
                                     Foreground="#B2AC88"
                                     Click="HyperlinkButton_Click"
                                     Margin="0,14,0,0"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>